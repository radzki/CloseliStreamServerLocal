# Eoolii Camera Local Relay Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Network Configuration
# =============================================================================

# IP address to bind the relay server (0.0.0.0 for all interfaces)
RELAY_HOST=0.0.0.0

# Your local IP that cameras will connect to (the IP of your server on the camera's network)
# IMPORTANT: This must be the IP that cameras can reach (your host's network interface)
LOCAL_IP=192.168.1.100

# Main relay port (cameras connect here)
RELAY_PORT=50721

# Management CLI port
MGMT_PORT=50722

# =============================================================================
# TLS Certificates
# =============================================================================

# Path to SSL certificate and key
# You can generate self-signed certs with:
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout server.key -out server.crt -days 365
SERVER_CERT=./server.crt
SERVER_KEY=./server.key

# =============================================================================
# Default Device (optional, used as fallback)
# =============================================================================

# Default device ID if not parsed from connection
# Format: xxxxS_<mac_address_without_colons>
DEFAULT_DEVICE_ID=xxxxS_000000000000

# =============================================================================
# Stream Server Configuration (stream_server.py)
# =============================================================================

# HTTP port for serving video/audio streams (single camera mode)
HTTP_PORT=8080

# Product key (from camera pairing, used in handshake)
PRODUCT_KEY=your_product_key

# User email (used in authentication handshake - may not be validated)
USER_EMAIL=user@example.com

# =============================================================================
# Mock API Server Configuration (mock_api_server.py)
# =============================================================================

# Port for mock HTTPS API server (usually 443)
API_PORT=443

# =============================================================================
# Docker: Multi-Camera Configuration
# =============================================================================
# When using docker-compose, define device IDs for each camera stream server.
# Each camera gets its own stream server on a separate port.
#
# Usage:
#   docker-compose --profile camera1 --profile camera2 up -d
#
# Or start all cameras:
#   docker-compose --profile all-cameras up -d

# Camera 1 - Port 8081
CAMERA1_DEVICE_ID=xxxxS_000000000001

# Camera 2 - Port 8082
CAMERA2_DEVICE_ID=xxxxS_000000000002

# Camera 3 - Port 8083
CAMERA3_DEVICE_ID=xxxxS_000000000003

# Camera 4 - Port 8084
CAMERA4_DEVICE_ID=xxxxS_000000000004

# =============================================================================
# Debugging
# =============================================================================

# Enable debug logging (true/false)
DEBUG_MODE=false
